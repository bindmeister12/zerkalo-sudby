# Yandex Mobile Ads — рекламные блоки для нативной сборки (EAS)
# Заведите блоки в кабинете "РСЯ для приложений" и подставьте их ID.
# Без этих переменных провайдер автоматически падает в StubAdsProvider.
EXPO_PUBLIC_YANDEX_INTERSTITIAL_ID=
EXPO_PUBLIC_YANDEX_REWARDED_ID=

# Опционально — App ID для Android meta-data (если требует ваш SDK-клиент)
# Прокидывается в plugins.withYandexAds.androidAppId в app.json при необходимости.
# EXPO_PUBLIC_YANDEX_ANDROID_APP_ID=
